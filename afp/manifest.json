{
  "contract": "afp-app-repo/v1",
  "template": {
    "name": "afp-app-template",
    "version": "0.3.0"
  },
  "app": {
    "display_name": "FactoryDemo",
    "bundle_id": "art.neuralcraft.factorydemo",
    "platforms": [
      "ios"
    ],
    "identity_file": "Config/App.xcconfig"
  },
  "state_db": "afp/state.sqlite",
  "artifacts_dir": "afp/artifacts",
  "reports_dir": "afp/reports",
  "spec_dir": "spec",
  "verify": {
    "entrypoint": "Scripts/verify.sh",
    "report": "afp/artifacts/verify.json",
    "failure_summary": "Scripts/xcresult-summary.sh",
    "gates": [
      {
        "id": "gen",
        "oracle": "xcodegen regenerates the project cleanly"
      },
      {
        "id": "format",
        "oracle": "swift format lint --strict finds nothing"
      },
      {
        "id": "build_ios",
        "oracle": "iOS simulator build-for-testing succeeds, warnings as errors"
      },
      {
        "id": "unit_tests",
        "oracle": "all Swift Testing unit tests pass"
      },
      {
        "id": "ui_smoke",
        "oracle": "UITests/SmokeTests passes on simulator"
      },
      {
        "id": "store_lint",
        "oracle": "Store/ metadata present and within App Store limits"
      }
    ],
    "simulator": "iPhone 17 Pro Max"
  },
  "release": {
    "archive": "Scripts/archive.sh",
    "publish": "Scripts/release.sh",
    "screenshots": "Scripts/screenshots.sh",
    "human_gates": [
      "app_record_creation",
      "first_submission",
      "pricing",
      "kill_decision"
    ]
  },
  "skills": {
    "dir": ".skills",
    "vendor": [
      ".skills/vendor/asc"
    ],
    "first_party": [
      "scaffold-from-spec",
      "implement-milestone",
      "cross-review",
      "ui-polish-pass",
      "store-assets",
      "capture-screenshots",
      "release-train"
    ]
  }
}
